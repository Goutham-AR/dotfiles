{
  // ============================================
  // Editor Settings (from options.lua)
  // ============================================
  
  // Line numbers
  "editor.lineNumbers": "relative",
  
  // Mouse support
  "editor.mouseWheelZoom": false,
  
  // Indentation
  "editor.insertSpaces": true,
  "editor.detectIndentation": true,
  "editor.tabSize": 2,
  
  // Cursor and scrolling
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,
  "editor.cursorSurroundingLines": 10,
  
  // Whitespace visualization
  "editor.renderWhitespace": "all",
  
  // Search
  "search.smartCase": true,
  
  // Clipboard
  "editor.emptySelectionClipboard": false,
  
  // Split behavior
  "workbench.editor.openSideBySideDirection": "right",
  
  // Bracket colorization
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  
  // Minimap
  "editor.minimap.enabled": true,
  
  // Format on save
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  
  // Autoclose brackets
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingQuotes": "always",
  
  // Word wrap
  "editor.wordWrap": "off",
  
  // Suggest
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.snippetSuggestions": "top",
  
  // Inlay hints
  "editor.inlayHints.enabled": "on",
  
  // ============================================
  // Theme (from theme.lua - gruvbox-material)
  // ============================================
  "workbench.colorTheme": "Gruvbox Material Dark",
  "editor.tokenColorCustomizations": {
    "textMateRules": []
  },
  
  // ============================================
  // Files
  // ============================================
  "files.autoSave": "off",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  
  // ============================================
  // Git (from gitsigns.lua)
  // ============================================
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "gitlens.currentLine.enabled": false,
  "git.decorations.enabled": true,
  "scm.diffDecorations": "all",
  "scm.diffDecorationsGutterWidth": 1,
  
  // ============================================
  // Language-specific Settings (from LSP and conform.lua)
  // ============================================
  
  // JavaScript/TypeScript
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": false
  },
  
  // Python
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  
  // Lua
  "[lua]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.formatOnSave": false
  },
  
  // ============================================
  // Terminal
  // ============================================
  "terminal.integrated.fontFamily": "monospace",
  "terminal.integrated.fontSize": 14,
  "terminal.integrated.cursorBlinking": true,
  
  // ============================================
  // Workbench
  // ============================================
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": false,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.list.smoothScrolling": true,
  "workbench.tree.indent": 16,
  "workbench.iconTheme": "material-icon-theme",
  
  // ============================================
  // Explorer
  // ============================================
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  
  // ============================================
  // Breadcrumbs
  // ============================================
  "breadcrumbs.enabled": true,
  
  // ============================================
  // Copilot (from copilot.lua)
  // ============================================
  "github.copilot.enable": {
    "*": true
  },
  "github.copilot.editor.enableAutoCompletions": true,
  
  // ============================================
  // Language Server Settings
  // ============================================
  
  // TypeScript/JavaScript
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  
  // Python
  "python.languageServer": "Pylance",
  
  // ============================================
  // Vim Extension (if using VSCodeVim)
  // ============================================
  "vim.useSystemClipboard": true,
  "vim.leader": "<space>",
  "vim.hlsearch": true,
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "w"],
      "commands": ["workbench.action.files.save"]
    },
    {
      "before": ["<leader>", "v"],
      "commands": ["workbench.action.splitEditorRight"]
    },
    {
      "before": ["<leader>", "h"],
      "commands": ["workbench.action.splitEditorDown"]
    },
    {
      "before": ["<C-d>"],
      "after": ["<C-d>", "z", "z"]
    },
    {
      "before": ["<C-u>"],
      "after": ["<C-u>", "z", "z"]
    },
    {
      "before": ["J"],
      "after": ["m", "z", "J", "`", "z"]
    },
    {
      "before": ["<C-e>"],
      "commands": ["workbench.action.closeActiveEditor"]
    },
    {
      "before": ["g", "r", "n"],
      "commands": ["editor.action.rename"]
    },
    {
      "before": ["g", "r", "a"],
      "commands": ["editor.action.quickFix"]
    },
    {
      "before": ["g", "d"],
      "commands": ["editor.action.revealDefinition"]
    },
    {
      "before": ["g", "r", "r"],
      "commands": ["references-view.findReferences"]
    },
    {
      "before": ["g", "r", "i"],
      "commands": ["editor.action.goToImplementation"]
    },
    {
      "before": ["g", "r", "d"],
      "commands": ["editor.action.revealDefinition"]
    },
    {
      "before": ["g", "r", "D"],
      "commands": ["editor.action.revealDeclaration"]
    },
    {
      "before": ["g", "r", "t"],
      "commands": ["editor.action.goToTypeDefinition"]
    },
    {
      "before": ["<leader>", "k"],
      "commands": ["editor.action.showHover"]
    },
    {
      "before": ["<leader>", "d", "s"],
      "commands": ["workbench.action.gotoSymbol"]
    },
    {
      "before": ["g", "W"],
      "commands": ["workbench.action.showAllSymbols"]
    },
    {
      "before": ["<leader>", "q"],
      "commands": ["workbench.actions.view.problems"]
    },
    {
      "before": ["<leader>", "l", "l"],
      "commands": ["editor.action.formatDocument"]
    },
    {
      "before": ["]", "c"],
      "commands": ["workbench.action.editor.nextChange"]
    },
    {
      "before": ["[", "c"],
      "commands": ["workbench.action.editor.previousChange"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["<leader>", "c"],
      "commands": ["editor.action.commentLine"]
    },
    {
      "before": ["<leader>", "p"],
      "after": ["\"", "_", "d", "P"]
    }
  ],
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false
  },
  
  // ============================================
  // Additional Settings for Better Experience
  // ============================================
  "editor.semanticHighlighting.enabled": true,
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.fontFamily": "Menlo, Monaco, 'Courier New', monospace",
  
  // Disable telemetry
  "telemetry.telemetryLevel": "off",
  
  // Auto-update extensions
  "extensions.autoUpdate": true,
  
  // Problems view
  "problems.decorations.enabled": true,
  
  // Diagnostics
  "javascript.validate.enable": true,
  "typescript.validate.enable": true
}
